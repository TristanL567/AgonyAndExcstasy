%==== 4b. Data findings =======================================================%

\begin{frame}{Methodology III: ``Permanent-CSI''}
\small

\begin{alertblock}{Dealing with recovering firms}
\scriptsize
Permanent-CSI starts from a confirmed temporary-CSI event and walks it through two stages. The objective is to ensure whether a temporary-CSI flaged firm actually did not recover. This can either be due to a bankruptcy indicator or a prolonged stagnation (say 5 years), which is more indicative of permanent firm decline.
\end{alertblock}

\vspace{0.4em}

\begin{center}
\hspace*{-1.2cm}%
\begin{tikzpicture}[
  font=\scriptsize,
  node distance=4mm,
  csibox/.style={draw, rounded corners=2pt, minimum height=8mm, inner sep=3pt, align=center},
  csientry/.style={csibox, fill=grey!50, draw=darkgrey, text width=3.6cm},
  csicheck/.style={csibox, fill=orange!12, draw=orange!60!black, text width=4.0cm},
  csipos/.style={csibox, fill=warningRed!18, draw=warningRed, text width=3.2cm},
  csineg/.style={csibox, fill=teal!18, draw=teal!60!black, text width=3.2cm},
  csiedge/.style={->, >=stealth, thick},
  nolab/.style={right, font=\tiny, text=darkgrey},
  altlab/.style={font=\tiny, text=darkgrey}
]
% Top: entry event
\node[csientry] (entry) {\textbf{Confirmed CSI event}\\[-1pt]\tiny eligible firm-year};

% Tier (i)
\node[csicheck, below=4mm of entry] (t1) {\textbf{Tier (i): adverse delisting}\\[-1pt]\tiny within 36 months of trigger?};

% Tier (ii)
\node[csicheck, below=14mm of t1] (t2) {\textbf{Tier (ii): 5 years observed}\\[-1pt]\tiny recovered above $M$ within 5y?};

% Single left-side red outcome — placed between the two tiers, offset left
\coordinate (midy) at ($(t1.south)!0.5!(t2.north)$);
\node[csipos, anchor=east] at ([xshift=-12mm]t1.west |- midy) (term) {$y^{perm}=1$};

% Right-side outcome — same height as Tier (ii)
\node[csipos, right=12mm of t2] (dur) {$y^{perm}=1$};

% Below Tier (ii) — Recovered branch
\node[csineg, below=8mm of t2] (recov) {$y^{perm}=0$};

% Edges
\draw[csiedge] (entry) -- (t1);
\draw[csiedge] (t1.west) -| node[altlab, above, pos=0.2] {Yes} (term.north);
\draw[csiedge] (t1) -- node[nolab] {No} (t2);
% \draw[csiedge] (t2.west) -| node[altlab, below, pos=0.2] {No} (term.south);
\draw[csiedge] (t2.east) -- node[altlab, above] {No} (dur.west);
\draw[csiedge] (t2) -- node[nolab] {Recovered} (recov);
\end{tikzpicture}
\end{center}

\vspace{0.3em}

\begin{block}{Contrast with temporary CSI}
\scriptsize
Temporary CSI removes any flagged firm for a fixed lockout, regardless of subsequent recovery. Permanent-CSI only retains firms that demonstrably recover above $M$ within five years; all other CSI events --- terminal failure, durable non-recovery, or censored within five years --- produce $y^{perm}=1$. Resulting prevalence: 6,344 positives across 626,080 firm-years (1.01\%); full split in Appendix.
\end{block}

\end{frame}

%==== 4b. Data findings =======================================================%

\begin{frame}{Dataset: Descriptive Statistics}
\scriptsize
\begin{alertblock}{CSI positives are rare and economically distinct from non-positives}
\scriptsize
Both label definitions isolate a small distressed tail. The key contrast is not only prevalence: positive firms are much smaller and show worse realized returns and profitability.
\end{alertblock}

\vspace{0.05em}
\begin{table}[ht]
\centering
\setlength{\tabcolsep}{1.85pt}
\begin{tabular}{L{1.25cm}L{0.95cm}R{0.35cm}R{1.0cm}R{0.75cm}R{0.8cm}R{1.05cm}R{0.85cm}R{0.95cm}}
\toprule
Sample & CSI & y & Obs. & Share & Firms & Median mcap & Ann. ret. & ROA \\
\midrule
Full & Temp. & 0 & 594,455 & 98.57\% & 19,565 & 350.9 & 4.9\% & 1.6\% \\
Full & Temp. & 1 & \textbf{8,647} & 1.43\% & 5,677 & \textbf{68.7} & \textbf{-35.0\%} & \textbf{-18.8\%} \\
Full & Perm. & 0 & 599,006 & 98.90\% & 19,565 & 249.3 & 4.2\% & 1.5\% \\
Full & Perm. & 1 & 6,650 & 1.10\% & 4,808 & \textbf{66.2} & \textbf{-37.5\%} & \textbf{-19.3\%} \\
\bottomrule
\end{tabular}
\end{table}

\begin{block}{Read}
\scriptsize
The full temporary-CSI classification contains \textbf{8,647} positive annual cells. Positive labels identify much smaller firms with sharply negative returns and profitability.
\end{block}
\remarkfoot{Obs. are annual label cells; Firms are unique firms. Market cap, assets, and sales are USD millions.}
\end{frame}

